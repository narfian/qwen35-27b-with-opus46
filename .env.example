# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and will NOT be committed.

# Hugging Face token (https://huggingface.co/settings/tokens)
# Required for: pushing merged / GGUF artifacts to the Hub, gated model downloads.
HF_TOKEN=

# Weights & Biases API key (https://wandb.ai/authorize)
# Required when SFTConfig.report_to == "wandb".
WANDB_API_KEY=

# Optional: override the W&B project name.
# WANDB_PROJECT=qwen35-27b-with-opus46
